{% assign fallback_photos = 'review-scene-1.png,review-scene-2.png,review-scene-3.png,review-scene-4.png' | split: ',' %}
{% assign fallback_avatars = 'review-avatar-1.png,review-avatar-2.png,review-avatar-1.png,review-avatar-2.png' | split: ',' %}

<section class="reviews page-width">
  <div class="centered-heading">
    <p class="eyebrow">Customer Reviews</p>
    <h2>{{ section.settings.heading }}</h2>
  </div>
  <div class="reviews-grid">
    {% for block in section.blocks %}
      {% assign image_index = forloop.index0 %}
      <article class="review-card" {{ block.shopify_attributes }}>
        {% if block.settings.photo != blank %}
          {{ block.settings.photo | image_url: width: 900 | image_tag: loading: 'lazy', alt: block.settings.name }}
        {% else %}
          {{ fallback_photos[image_index] | asset_url | image_tag: loading: 'lazy', alt: block.settings.name }}
        {% endif %}
        <div class="review-card__body">
          <div class="stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {% for i in (1..5) %}{% if i <= block.settings.rating %}★{% else %}☆{% endif %}{% endfor %}
          </div>
          <p>"{{ block.settings.text }}"</p>
          <div class="reviewer">
            {% if block.settings.avatar != blank %}
              {{ block.settings.avatar | image_url: width: 96 | image_tag: loading: 'lazy', alt: block.settings.name }}
            {% else %}
              {{ fallback_avatars[image_index] | asset_url | image_tag: loading: 'lazy', alt: block.settings.name }}
            {% endif %}
            <div>
              <strong>{{ block.settings.name }}</strong>
              <span>Verified buyer</span>
            </div>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Customer reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by real cats & their humans." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Sophie L." },
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review", "default": "My cat hasn't touched his old scratcher since this arrived. The design is so sleek it actually looks like furniture." },
        { "type": "image_picker", "id": "photo", "label": "Scene photo" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review", "settings": { "name": "Jun K." } },
        { "type": "review", "settings": { "name": "Maria G." } },
        { "type": "review", "settings": { "name": "Hana P.", "rating": 4 } }
      ]
    }
  ]
}
{% endschema %}
