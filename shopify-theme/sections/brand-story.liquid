<section class="brand-story page-width">
  <div class="brand-story__copy">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <div class="rte">{{ section.settings.text }}</div>
  </div>
  <div class="brand-story__media">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', alt: section.settings.heading }}
    {% else %}
      {{ 'grooming.jpg' | asset_url | image_tag: loading: 'lazy', alt: section.settings.heading }}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why we built PawKasa" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We believe cats deserve better." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>As cat lovers and long-time pet parents, we grew tired of choosing between products that were functional but ugly, or beautiful but ignored by our cats. So we set out to build a brand that refuses to compromise.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "presets": [{ "name": "Brand story" }]
}
{% endschema %}
