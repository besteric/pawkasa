<section class="page-width search-page">
  <div class="page-hero page-hero--simple">
    <p class="eyebrow">Search</p>
    <h1>Search PawKasa</h1>
  </div>
  <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products">
    <button class="button button--primary" type="submit">Search</button>
  </form>
  {% if search.performed %}
    <div class="product-grid">
      {% for item in search.results %}
        {% if item.object_type == 'product' %}
          {% render 'product-card', product_card: item %}
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Main search"
}
{% endschema %}
