<section class="collection-page page-width">
  <div class="page-hero page-hero--simple">
    <p class="eyebrow">Products</p>
    <h1>{{ collection.title | default: 'All products' }}</h1>
    {% if collection.description != blank %}
      <div class="rte">{{ collection.description }}</div>
    {% else %}
      <p>Premium scratching boards and care essentials, all powered by Shopify catalog, inventory, and checkout.</p>
    {% endif %}
  </div>

  {% paginate collection.products by section.settings.products_per_page %}
    <div class="product-grid product-grid--collection">
      {% for product in collection.products %}
        {% render 'product-card', product_card: product %}
      {% else %}
        <p>No products found in this collection yet.</p>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <nav class="pagination" aria-label="Pagination">
        {{ paginate | default_pagination }}
      </nav>
    {% endif %}
  {% endpaginate %}
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 36, "step": 4, "default": 12 }
  ]
}
{% endschema %}
