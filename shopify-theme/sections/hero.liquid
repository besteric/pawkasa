<section class="hero">
  <div class="page-width hero__grid">
    <div class="hero__copy">
      <span class="pill">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
      <div class="button-row">
        <a class="button button--dark" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a>
        <a class="button button--outline" href="{{ section.settings.secondary_link | default: '/pages/about-us' }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
    <div class="hero__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'eager', alt: section.settings.heading }}
      {% else %}
        {{ 'hero-pets.jpg' | asset_url | image_tag: loading: 'eager', alt: section.settings.heading }}
      {% endif %}
      <div class="hero__badge">
        <span>✦</span>
        <div>
          <small>Loved by</small>
          <strong>2M+ cat families</strong>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Premium Cat Care" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "The Journey\nwith Cats,\nPawKasa." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Designing every product with one core belief — nurturing empathy, communication, and harmony between cats and people." },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Shop products" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Our story" },
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
