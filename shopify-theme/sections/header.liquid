<header class="site-header">
  {% if section.settings.announcement != blank %}
    <div class="announcement">{{ section.settings.announcement }}</div>
  {% endif %}

  <div class="header-inner page-width">
    <a class="brand" href="{{ routes.root_url }}">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 240 | image_tag: alt: shop.name, loading: 'eager' }}
      {% else %}
        {{ shop.name | default: 'PawKasa' }}
      {% endif %}
    </a>

    <nav class="desktop-nav" aria-label="Main navigation">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" {% if link.current %}aria-current="page"{% endif %}>{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="header-actions">
      <a href="{{ routes.search_url }}" aria-label="Search">
        <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" aria-label="Account">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
      {% endif %}
      <button class="cart-trigger" type="button" aria-label="Open cart" data-cart-open>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
      </button>
      <button class="mobile-menu-button" type="button" aria-label="Menu" data-mobile-menu-toggle>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="mobile-nav page-width" aria-label="Mobile navigation" data-mobile-menu>
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
  </nav>
</header>

<div class="cart-overlay" data-cart-overlay></div>
<aside class="cart-drawer" aria-label="Shopping cart" data-cart-drawer>
  <div class="cart-drawer__header">
    <div>
      <p class="eyebrow">PawKasa Cart</p>
      <h2>Your picks</h2>
    </div>
    <button type="button" aria-label="Close cart" data-cart-close>&times;</button>
  </div>
  <div class="cart-drawer__items" data-cart-items>
    {% if cart.item_count == 0 %}
      <div class="empty-cart">
        <h3>Your cart is empty</h3>
        <p>Add a scratcher or two, then checkout with Shopify secure checkout.</p>
        <a class="button button--primary" href="{{ routes.all_products_collection_url }}">Shop products</a>
      </div>
    {% else %}
      {% for item in cart.items %}
        <div class="cart-line" data-line-key="{{ item.key }}">
          {{ item.image | image_url: width: 180 | image_tag: loading: 'lazy', alt: item.product.title }}
          <div>
            <h3>{{ item.product.title }}</h3>
            <p>{{ item.final_line_price | money }}</p>
            <div class="qty-controls">
              <button type="button" data-cart-change data-key="{{ item.key }}" data-quantity="{{ item.quantity | minus: 1 }}">-</button>
              <span>{{ item.quantity }}</span>
              <button type="button" data-cart-change data-key="{{ item.key }}" data-quantity="{{ item.quantity | plus: 1 }}">+</button>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
  <div class="cart-drawer__footer">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <strong data-cart-subtotal>{{ cart.total_price | money }}</strong>
    </div>
    <p>Taxes, shipping, and payment methods are calculated in Shopify checkout.</p>
    <a class="button button--dark" href="{{ routes.cart_url }}">View cart</a>
    <a class="button button--primary" href="/checkout">Checkout</a>
  </div>
</aside>

{% schema %}
{
  "name": "Header",
  "class": "shopify-section-header",
  "settings": [
    { "type": "text", "id": "announcement", "label": "Announcement", "default": "Free US Shipping on orders over $50" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
