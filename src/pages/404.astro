---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found | PawKasa">
  <div class="flex min-h-screen items-center justify-center bg-muted">
    <div class="text-center">
      <h1 class="mb-4 text-4xl font-bold">404</h1>
      <p class="mb-4 text-xl text-muted-foreground">Oops! Page not found</p>
      <a href="/" class="text-brand-yellow hover:text-brand-yellow/80 underline">
        Return to Home
      </a>
    </div>
  </div>
</Layout>