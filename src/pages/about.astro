---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us — PawKasa" description="PawKasa is a premium cat care brand leading the way toward a healthier pet culture.">
  <Header />
  <main class="flex-1 min-h-screen flex flex-col bg-background">
    <section class="bg-brand-orange">
      <div class="container mx-auto px-6 py-20 md:py-28">
        <p class="text-sm font-medium uppercase tracking-widest text-brand-ink/70">About PawKasa</p>
        <h1 class="mt-4 font-display font-bold text-5xl md:text-7xl text-brand-ink leading-[0.95] max-w-4xl">
          Seeing the world through the eyes of cats.
        </h1>
        <p class="mt-6 text-lg text-brand-ink/80 max-w-2xl">
          We are a premium cat care brand leading the way toward a healthier
          pet culture — building genuine empathy, communication, and harmony
          between cats and people.
        </p>
      </div>
    </section>

    <section class="container mx-auto px-6 py-24 grid md:grid-cols-2 gap-12 items-center">
      <img
        src="/images/hero-pets.jpg"
        alt="Cats in a clean bright space"
        loading="lazy"
        class="rounded-[2rem] aspect-[4/3] object-cover w-full shadow-soft"
      />
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-brand-blue">Our Story</p>
        <h2 class="mt-3 font-heading font-bold text-4xl md:text-5xl text-brand-ink leading-tight">
          From scratching essentials to a global cat IP.
        </h2>
        <p class="mt-6 text-muted-foreground leading-relaxed">
          What began as a small company creating cat scratching essentials has
          evolved into a brand expanding across industries that enrich the
          lives of both cats and their families. Today PawKasa is Korea's
          No.1 premium cat IP in brand awareness — and growing globally.
        </p>
        <p class="mt-4 text-muted-foreground leading-relaxed">
          We design every product and service with one core belief:
          nurturing genuine connection between cats and people.
        </p>
      </div>
    </section>

    <section class="bg-muted py-24">
      <div class="container mx-auto px-6">
        <h2 class="font-heading font-bold text-4xl md:text-5xl text-brand-ink text-center max-w-3xl mx-auto leading-tight">
          What we believe.
        </h2>
        <div class="mt-12 grid md:grid-cols-3 gap-6">
          <div class="bg-card rounded-3xl p-8 border border-border">
            <div class="w-12 h-12 rounded-2xl bg-brand-orange flex items-center justify-center text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            </div>
            <h3 class="mt-5 font-heading font-bold text-2xl text-brand-ink">Cat Humanization</h3>
            <p class="mt-2 text-muted-foreground leading-relaxed">Treating cats as family — designing for their genuine needs and feelings.</p>
          </div>
          <div class="bg-card rounded-3xl p-8 border border-border">
            <div class="w-12 h-12 rounded-2xl bg-brand-cream flex items-center justify-center text-brand-ink">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.902a.5.5 0 0 1-.001-.95l6.135-1.901A2 2 0 0 0 9.937 8.5l1.901-6.135a.5.5 0 0 1 .95 0l1.901 6.135A2 2 0 0 0 15.5 9.937l6.135 1.902a.5.5 0 0 1 0 .95l-6.135 1.901A2 2 0 0 0 15.063 15.5l-1.901 6.135a.5.5 0 0 1-.95 0z"/></svg>
            </div>
            <h3 class="mt-5 font-heading font-bold text-2xl text-brand-ink">Design Excellence</h3>
            <p class="mt-2 text-muted-foreground leading-relaxed">Four-time Global Design Award winner. Form and function in harmony.</p>
          </div>
          <div class="bg-card rounded-3xl p-8 border border-border">
            <div class="w-12 h-12 rounded-2xl bg-brand-blue flex items-center justify-center text-brand-ink">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            </div>
            <h3 class="mt-5 font-heading font-bold text-2xl text-brand-ink">Global Mindset</h3>
            <p class="mt-2 text-muted-foreground leading-relaxed">Built in Korea, embraced worldwide. From TikTok Shop to Amazon US.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="container mx-auto px-6 py-24 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-brand-orange flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          Recognition
        </p>
        <h2 class="mt-3 font-heading font-bold text-4xl md:text-5xl text-brand-ink leading-tight">
          Four-time Global Design Award winner.
        </h2>
        <p class="mt-6 text-muted-foreground leading-relaxed">
          From iF Design and Red Dot to Good Design and K-Design, our work has
          been recognized worldwide for its competitive edge — proving that cat
          care can be both meaningful and beautifully designed.
        </p>
      </div>
      <img
        src="/images/grooming.jpg"
        alt="A cat being groomed gently"
        loading="lazy"
        class="rounded-[2rem] aspect-[4/3] object-cover w-full shadow-soft"
      />
    </section>
  </main>
  <Footer />
</Layout>