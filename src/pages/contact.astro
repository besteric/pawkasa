---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — PawKasa" description="Get in touch with PawKasa for partnerships and collaborations.">
  <Header />
  <main class="flex-1 min-h-screen flex flex-col bg-background">
    <section class="bg-brand-orange">
      <div class="container mx-auto px-6 py-20 md:py-24">
        <p class="text-sm font-medium uppercase tracking-widest text-brand-ink/70">Contact</p>
        <h1 class="mt-4 font-display font-bold text-5xl md:text-7xl text-brand-ink leading-[0.95] max-w-3xl">
          Let's build something meaningful together.
        </h1>
        <p class="mt-6 text-lg text-brand-ink/80 max-w-2xl">
          We're always open to new partnerships and collaborations. If you're
          interested in working with PawKasa, we'd love to hear from you.
        </p>
      </div>
    </section>

    <section class="container mx-auto px-6 py-20 grid lg:grid-cols-5 gap-12">
      <div class="lg:col-span-2 space-y-8">
        <div>
          <h2 class="font-heading font-bold text-3xl text-brand-ink">Have more questions?</h2>
          <p class="mt-3 text-muted-foreground">
            Feel free to reach out to our team — we usually reply within 1–2 business days.
          </p>
        </div>
        <div class="space-y-4">
          <a href="mailto:info@pawkasa.com" class="flex items-start gap-4 p-5 rounded-2xl border border-border hover:border-brand-orange hover:bg-accent transition-colors">
            <div class="w-10 h-10 rounded-xl bg-brand-orange flex items-center justify-center text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-brand-blue">Email</div>
              <div class="font-semibold text-brand-ink">info@pawkasa.com</div>
            </div>
          </a>
          <div class="flex items-start gap-4 p-5 rounded-2xl border border-border">
            <div class="w-10 h-10 rounded-xl bg-brand-mint flex items-center justify-center text-brand-ink">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-brand-orange">Headquarters</div>
              <div class="font-semibold text-brand-ink">Seoul, South Korea</div>
            </div>
          </div>
        </div>
      </div>

      <form id="contact-form" class="lg:col-span-3 bg-muted rounded-[2rem] p-8 md:p-10 space-y-5">
        <div>
          <label class="text-sm font-medium uppercase tracking-wider">What partnership are you interested in?</label>
          <div class="mt-3 flex flex-wrap gap-2" id="partnership-btns">
            {["Distribution", "Marketing", "Licensing / IP", "Wholesale", "Other"].map((p) => (
              <button
                type="button"
                data-partner={p}
                class="partner-btn px-4 py-2 rounded-full text-sm font-medium border transition-colors bg-card text-brand-ink border-border hover:border-brand-ink"
              >
                {p}
              </button>
            ))}
          </div>
          <input type="hidden" id="partner-type" name="partner_type" value="Distribution" />
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="text-sm font-medium">Name</label>
            <input id="name" name="name" required class="mt-1.5 bg-card h-12 rounded-xl border border-border w-full px-3 text-sm" />
          </div>
          <div>
            <label for="email" class="text-sm font-medium">Email</label>
            <input id="email" name="email" type="email" required class="mt-1.5 bg-card h-12 rounded-xl border border-border w-full px-3 text-sm" />
          </div>
          <div>
            <label for="phone" class="text-sm font-medium">Phone Number</label>
            <input id="phone" name="phone" class="mt-1.5 bg-card h-12 rounded-xl border border-border w-full px-3 text-sm" />
          </div>
          <div>
            <label for="company" class="text-sm font-medium">Team / Company</label>
            <input id="company" name="company" class="mt-1.5 bg-card h-12 rounded-xl border border-border w-full px-3 text-sm" />
          </div>
        </div>
        <div>
          <label for="message" class="text-sm font-medium">Message</label>
          <textarea id="message" name="message" required rows="5" class="mt-1.5 bg-card rounded-xl border border-border w-full px-3 py-2 text-sm"></textarea>
        </div>
        <p class="text-xs text-muted-foreground">
          By submitting, you agree to receive communications from PawKasa. View our
          privacy policy for more info.
        </p>
        <button type="submit" class="inline-flex items-center justify-center rounded-full h-12 px-8 bg-brand-orange text-white hover:bg-brand-orange/90 text-sm font-medium transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="m22 2-7 20-4-9-9-4Z"/><path d="m22 2-11 11"/></svg>
          Submit
        </button>
      </form>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const partnerBtns = document.querySelectorAll('.partner-btn');
  const partnerInput = document.getElementById('partner-type') as HTMLInputElement;

  partnerBtns[0]?.classList.add('bg-brand-ink', 'text-brand-cream', 'border-brand-ink');
  partnerBtns[0]?.classList.remove('bg-card', 'text-brand-ink');

  partnerBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      partnerBtns.forEach((b) => {
        b.classList.remove('bg-brand-ink', 'text-brand-cream', 'border-brand-ink');
        b.classList.add('bg-card', 'text-brand-ink');
      });
      btn.classList.add('bg-brand-ink', 'text-brand-cream', 'border-brand-ink');
      btn.classList.remove('bg-card', 'text-brand-ink');
      partnerInput.value = (btn as HTMLElement).dataset.partner || '';
    });
  });

  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thanks for reaching out — we\'ll get back to you soon!');
    (e.target as HTMLFormElement).reset();
  });
</script>