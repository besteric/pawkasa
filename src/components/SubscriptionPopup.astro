---
---

<div
  id="subscription-popup"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/55 px-3 py-4 sm:px-4 sm:py-6 backdrop-blur-[2px] transition-opacity duration-300"
  style="display: none;"
>
  <div class="relative max-h-[86vh] w-full max-w-[min(92vw,760px)] overflow-y-auto rounded-[22px] bg-[#fff4e9] shadow-[0_24px_90px_rgba(0,0,0,0.28)] md:max-w-[min(58vw,760px)]">
    <button
      id="popup-close"
      class="absolute right-3 top-3 z-20 rounded-full bg-[#fff4e9]/80 p-1 text-[#1c120a] backdrop-blur transition-transform hover:scale-110"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/>
        <path d="M6 6 18 18"/>
      </svg>
    </button>

    <div class="grid min-h-0 grid-cols-1 md:grid-cols-[minmax(0,0.42fr)_minmax(0,0.58fr)]">
      <div class="relative h-[150px] overflow-hidden bg-[#ff7a00] sm:h-[190px] md:h-auto md:min-h-[390px]">
        <img
          src="/images/subscription-banner-left.png"
          alt="PawKasa subscription offer banner"
          class="block h-full w-full object-cover object-center"
        />
      </div>

      <div class="relative flex min-h-0 items-center bg-[#fbf2e7] px-5 py-6 sm:px-6 sm:py-7 md:px-6 md:py-6">
        <div class="pointer-events-none absolute right-[8%] top-[12%] hidden text-[#ff7a00] md:block">
          <span class="text-3xl">♡</span>
        </div>

        <div class="mx-auto flex w-full max-w-[390px] flex-col items-center text-center">
          <h2 class="font-display text-[clamp(1.65rem,2.8vw,2.65rem)] font-bold leading-[0.98] text-[#24160d]">
            A little gift <span class="text-[#ff7a00]">♡</span>
            <br />
            for you &amp; your cat
          </h2>

          <div class="mt-2 h-2.5 w-[min(100%,17rem)] rounded-full bg-[#ffd46f]"></div>

          <p class="mt-3 text-[clamp(1rem,1.4vw,1.2rem)] leading-[1.3] text-[#2b1a10]">
            Get <span class="font-semibold text-[#ff7a00]">10% OFF</span> your first order
          </p>
          <p class="mt-1 max-w-[20rem] text-[clamp(0.78rem,0.95vw,0.9rem)] leading-[1.35] text-[#2b1a10]">
            + early access to new arrivals &amp; exclusive drops <span class="text-[#7cc7e8]">✧</span>
          </p>

          <form id="sub-form" class="mt-4 w-full">
            <label class="flex h-11 items-center gap-2 rounded-[13px] border-[1.5px] border-[#2b1a10] bg-white px-3 shadow-[0_2px_0_rgba(0,0,0,0.03)]">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center text-[#2b1a10]">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="5" width="18" height="14" rx="2"/>
                  <path d="m3 7 9 6 9-6"/>
                </svg>
              </span>
              <input
                type="email"
                required
                placeholder="Enter your email address"
                class="w-full bg-transparent text-sm text-[#2b1a10] placeholder:text-[#a0a0a0] focus:outline-none"
              />
            </label>

            <button
              type="submit"
              class="mt-3 flex h-11 w-full items-center justify-center rounded-[13px] bg-[#ff7a00] text-base font-bold text-white shadow-[0_8px_0_rgba(0,0,0,0.04)] transition-all hover:translate-y-[-1px] hover:brightness-[1.02]"
            >
              Get My 10% Off 🐾
            </button>
          </form>

          <p class="mt-3 flex items-center justify-center gap-1.5 text-xs text-[#2b1a10]">
            <span>🔒</span>
            <span>No spam, just good stuff. <span class="underline">Unsubscribe anytime.</span></span>
          </p>

          <div class="mt-4 w-full border-t border-dashed border-[#f0c98a] pt-4">
            <p class="text-sm text-[#2b1a10]">
              Follow us for daily cat moments <span class="text-[#ff7a00]">♡</span>
            </p>
            <div class="mt-3 grid grid-cols-3 gap-2">
              <a href="https://instagram.com/pawkasa" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1.5 text-[#2b1a10]">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#ffd45f] text-[#1c120a]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="5"/>
                    <circle cx="12" cy="12" r="4.5"/>
                    <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/>
                  </svg>
                </div>
                <span class="text-[11px]">@pawkasa</span>
              </a>
              <a href="https://tiktok.com/@pawkasa" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1.5 text-[#2b1a10]">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#bfe5f6] text-[#1c120a]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 4v10.5a4.5 4.5 0 1 1-4.5-4.5"/>
                    <path d="M14 4c1 2.5 2.8 4.2 5 4.5"/>
                  </svg>
                </div>
                <span class="text-[11px]">@pawkasa</span>
              </a>
              <a href="https://pinterest.com/pawkasa" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1.5 text-[#2b1a10]">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#f6c0c0] text-[#1c120a]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 21c1.5-3.5 4-12 4-14a4 4 0 1 0-8 0c0 1.8.8 3 2 3 1.7 0 2.5-1.8 2.5-3.2 0-1.1-.5-2-1.5-2"/>
                  </svg>
                </div>
                <span class="text-[11px]">@pawkasa</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const popup = document.getElementById('subscription-popup');
  const closeBtn = document.getElementById('popup-close');
  const form = document.getElementById('sub-form');

  if (popup && closeBtn) {
    setTimeout(() => {
      popup.style.display = 'flex';
      requestAnimationFrame(() => {
        popup.style.opacity = '1';
      });
    }, 1500);

    const closePopup = () => {
      popup.style.opacity = '0';
      setTimeout(() => {
        popup.style.display = 'none';
      }, 300);
    };

    closeBtn.addEventListener('click', closePopup);

    popup.addEventListener('click', (e) => {
      if (e.target === popup) closePopup();
    });
  }

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input');
      if (input) {
        alert(`🎉 Welcome to the PawKasa family! Your 10% off code has been sent to ${input.value}`);
        form.reset();
        popup.style.opacity = '0';
        setTimeout(() => {
          popup.style.display = 'none';
        }, 300);
      }
    });
  }
</script>
