---
---

<div
  id="subscription-popup"
  class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-brand-ink/50 backdrop-blur-sm transition-opacity duration-300"
  style="display: none;"
>
  <div class="relative bg-brand-mint/30 border-2 border-brand-mint/50 rounded-[2rem] overflow-hidden max-w-2xl w-full shadow-2xl">
    <button
      id="popup-close"
      class="absolute top-4 right-4 z-10 w-8 h-8 rounded-full bg-white/80 hover:bg-white flex items-center justify-center text-muted-foreground hover:text-brand-ink transition-colors"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="grid md:grid-cols-5 bg-white/60 backdrop-blur-sm rounded-[1.85rem] m-1">
      {/* Left Image */}
      <div class="md:col-span-2 relative bg-gradient-to-br from-brand-orange/20 via-brand-cream/40 to-brand-mint/30 overflow-hidden rounded-l-[1.8rem]">
        <img
          src="/images/grooming.jpg"
          alt="A happy cat with PawKasa products"
          width="600"
          height="600"
          class="w-full h-48 md:h-full object-cover mix-blend-multiply"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-mint/60 to-transparent"></div>
        <div class="absolute bottom-3 left-3 bg-white rounded-full px-3 py-1 text-xs font-bold text-brand-blue shadow-sm">
          🐾 2M+ cat families
        </div>
      </div>

      {/* Right Content */}
      <div class="md:col-span-3 p-8 md:p-10 flex flex-col justify-center">
        <div class="inline-flex items-center gap-1 bg-brand-blue/10 rounded-full px-3 py-1 text-xs font-medium text-brand-blue mb-4">
          ✨ Exclusive offer
        </div>
        <h2 class="font-heading font-bold text-2xl md:text-3xl leading-tight text-brand-ink">
          A little gift for you &amp; your cat 🐾
        </h2>
        <p class="mt-3 text-muted-foreground leading-relaxed">
          Get 10% off your first order + early access to new arrivals &amp; exclusive drops
        </p>

        <form id="sub-form" class="mt-5 space-y-3">
          <input
            type="email"
            required
            placeholder="Your email address"
            class="w-full h-12 px-5 rounded-full border-2 border-brand-mint/60 bg-white text-brand-ink placeholder:text-muted-foreground focus:outline-none focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 transition-all text-sm"
          />
          <button
            type="submit"
            class="w-full h-12 rounded-full bg-brand-blue text-white font-heading font-bold text-sm hover:bg-brand-blue/90 transition-all active:scale-[0.98] flex items-center justify-center gap-2 shadow-md shadow-brand-blue/20"
          >
            Get My 10% Off 🐾
          </button>
        </form>

        <p class="mt-3 text-xs text-muted-foreground text-center">
          No spam. Just cute things and better homes for your cat.
        </p>

        {/* Social */}
        <div class="mt-6 pt-6 border-t border-brand-mint/40 text-center">
          <p class="text-xs text-muted-foreground mb-3">Follow us for daily cat moments</p>
          <div class="flex items-center justify-center gap-4">
            <a
              href="https://instagram.com/pawkasa"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-brand-blue/10 text-brand-blue hover:bg-brand-blue hover:text-white transition-all flex items-center justify-center"
              aria-label="Instagram"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a
              href="https://tiktok.com/@pawkasa"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-brand-blue/10 text-brand-blue hover:bg-brand-blue hover:text-white transition-all flex items-center justify-center"
              aria-label="TikTok"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
            </a>
            <a
              href="https://pinterest.com/pawkasa"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-brand-blue/10 text-brand-blue hover:bg-brand-blue hover:text-white transition-all flex items-center justify-center"
              aria-label="Pinterest"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="12" y1="8" x2="12" y2="16"/></svg>
            </a>
          </div>
          <p class="mt-2 text-xs font-medium text-brand-blue">@pawkasa</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const popup = document.getElementById('subscription-popup');
  const closeBtn = document.getElementById('popup-close');
  const form = document.getElementById('sub-form');

  if (popup && closeBtn) {
    // Always show during testing
    setTimeout(() => {
      popup.style.display = 'flex';
      requestAnimationFrame(() => {
        popup.style.opacity = '1';
      });
    }, 1500);

    const closePopup = () => {
      popup.style.opacity = '0';
      setTimeout(() => {
        popup.style.display = 'none';
      }, 300);
    };

    closeBtn.addEventListener('click', closePopup);

    popup.addEventListener('click', (e) => {
      if (e.target === popup) closePopup();
    });
  }

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input');
      if (input) {
        alert(`🎉 Welcome to the PawKasa family! Your 10% off code has been sent to ${input.value}`);
        form.reset();
        popup.style.opacity = '0';
        setTimeout(() => {
          popup.style.display = 'none';
        }, 300);
      }
    });
  }
</script>
