---
---

<div
  id="subscription-popup"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/55 px-3 py-4 sm:px-4 sm:py-6 backdrop-blur-[2px] transition-opacity duration-300"
  style="display: none;"
>
  <div class="relative aspect-[2437/1596] max-h-[88vh] w-full max-w-[min(94vw,980px)] overflow-hidden rounded-[22px] bg-[#fff4e9] shadow-[0_24px_90px_rgba(0,0,0,0.28)] max-sm:h-[78vh] max-sm:max-w-[360px] max-sm:aspect-auto">
    <img
      src="/images/subscription-popup-bg.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover max-sm:object-[32%_center]"
    />
    <button
      id="popup-close"
      class="absolute right-[2.8%] top-[2.8%] z-20 rounded-full bg-[#fff4e9]/65 p-1 text-[#1c120a] backdrop-blur transition-transform hover:scale-110"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-7 md:w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/>
        <path d="M6 6 18 18"/>
      </svg>
    </button>

    <div class="absolute bottom-[6.5%] right-[4.8%] top-[37%] z-10 flex w-[44%] items-start justify-center md:bottom-[7%] md:right-[5.6%] md:top-[38.5%] md:w-[42.5%] max-sm:inset-x-4 max-sm:bottom-4 max-sm:top-auto max-sm:w-auto max-sm:rounded-2xl max-sm:bg-[#fbf2e7]/92 max-sm:p-3 max-sm:backdrop-blur">
      <div class="flex w-full max-w-[430px] flex-col items-center text-center">
          <p class="text-[clamp(0.7rem,1.6vw,1.18rem)] leading-[1.25] text-[#2b1a10]">
            Get <span class="font-semibold text-[#ff7a00]">10% OFF</span> your first order
          </p>
          <p class="mt-1 max-w-[22rem] text-[clamp(0.58rem,1.1vw,0.9rem)] leading-[1.25] text-[#2b1a10]">
            + early access to new arrivals &amp; exclusive drops <span class="text-[#7cc7e8]">✧</span>
          </p>

          <form id="sub-form" class="mt-[3%] w-full">
            <label class="flex h-9 items-center gap-2 rounded-[11px] border-[1.5px] border-[#2b1a10] bg-white/96 px-3 shadow-[0_2px_0_rgba(0,0,0,0.03)] sm:h-10 md:h-11">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center text-[#2b1a10]">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-[22px] md:w-[22px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="5" width="18" height="14" rx="2"/>
                  <path d="m3 7 9 6 9-6"/>
                </svg>
              </span>
              <input
                type="email"
                required
                placeholder="Enter your email address"
                class="w-full bg-transparent text-[11px] text-[#2b1a10] placeholder:text-[#a0a0a0] focus:outline-none sm:text-xs md:text-sm"
              />
            </label>

            <button
              type="submit"
              class="mt-2 flex h-9 w-full items-center justify-center rounded-[11px] bg-[#ff7a00] text-xs font-bold text-white shadow-[0_8px_0_rgba(0,0,0,0.04)] transition-all hover:translate-y-[-1px] hover:brightness-[1.02] sm:h-10 sm:text-sm md:h-11 md:text-base"
            >
              Get My 10% Off 🐾
            </button>
          </form>

          <p class="mt-2 flex items-center justify-center gap-1 text-[9px] text-[#2b1a10] sm:text-[10px] md:text-xs">
            <span>🔒</span>
            <span>No spam, just good stuff. <span class="underline">Unsubscribe anytime.</span></span>
          </p>

          <div class="mt-3 w-full border-t border-dashed border-[#f0c98a] pt-3 md:mt-4 md:pt-4">
            <p class="text-[10px] text-[#2b1a10] sm:text-xs md:text-sm">
              Follow us for daily cat moments <span class="text-[#ff7a00]">♡</span>
            </p>
            <div class="mt-2 grid grid-cols-3 gap-2 md:mt-3">
              <a href="https://instagram.com/pawkasa" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1.5 text-[#2b1a10]">
                <div class="flex h-7 w-7 items-center justify-center rounded-full bg-[#ffd45f] text-[#1c120a] sm:h-8 sm:w-8 md:h-10 md:w-10">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-[21px] md:w-[21px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="5"/>
                    <circle cx="12" cy="12" r="4.5"/>
                    <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/>
                  </svg>
                </div>
                <span class="text-[8px] sm:text-[9px] md:text-[11px]">@pawkasa</span>
              </a>
              <a href="https://tiktok.com/@pawkasa" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1.5 text-[#2b1a10]">
                <div class="flex h-7 w-7 items-center justify-center rounded-full bg-[#bfe5f6] text-[#1c120a] sm:h-8 sm:w-8 md:h-10 md:w-10">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-[21px] md:w-[21px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 4v10.5a4.5 4.5 0 1 1-4.5-4.5"/>
                    <path d="M14 4c1 2.5 2.8 4.2 5 4.5"/>
                  </svg>
                </div>
                <span class="text-[8px] sm:text-[9px] md:text-[11px]">@pawkasa</span>
              </a>
              <a href="https://pinterest.com/pawkasa" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1.5 text-[#2b1a10]">
                <div class="flex h-7 w-7 items-center justify-center rounded-full bg-[#f6c0c0] text-[#1c120a] sm:h-8 sm:w-8 md:h-10 md:w-10">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-[21px] md:w-[21px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 21c1.5-3.5 4-12 4-14a4 4 0 1 0-8 0c0 1.8.8 3 2 3 1.7 0 2.5-1.8 2.5-3.2 0-1.1-.5-2-1.5-2"/>
                  </svg>
                </div>
                <span class="text-[8px] sm:text-[9px] md:text-[11px]">@pawkasa</span>
              </a>
            </div>
          </div>
      </div>
    </div>
  </div>
</div>

<script>
  const popup = document.getElementById('subscription-popup');
  const closeBtn = document.getElementById('popup-close');
  const form = document.getElementById('sub-form');

  if (popup && closeBtn) {
    setTimeout(() => {
      popup.style.display = 'flex';
      requestAnimationFrame(() => {
        popup.style.opacity = '1';
      });
    }, 1500);

    const closePopup = () => {
      popup.style.opacity = '0';
      setTimeout(() => {
        popup.style.display = 'none';
      }, 300);
    };

    closeBtn.addEventListener('click', closePopup);

    popup.addEventListener('click', (e) => {
      if (e.target === popup) closePopup();
    });
  }

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input');
      if (input) {
        alert(`🎉 Welcome to the PawKasa family! Your 10% off code has been sent to ${input.value}`);
        form.reset();
        popup.style.opacity = '0';
        setTimeout(() => {
          popup.style.display = 'none';
        }, 300);
      }
    });
  }
</script>
