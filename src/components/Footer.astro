---
const year = new Date().getFullYear();
---

<section class="bg-brand-orange">
  <div class="container mx-auto grid items-center gap-8 px-6 py-12 md:grid-cols-[0.45fr_1fr] md:py-14 lg:gap-12">
    <div class="relative mx-auto w-full max-w-sm">
      <img
        src="/images/newsletter-cat-box.png"
        alt="PawKasa cat peeking out of a box"
        loading="lazy"
        class="mx-auto w-full max-w-[320px] object-contain md:max-w-[380px]"
      />
    </div>

    <div class="relative text-white">
      <div class="hidden md:block absolute -left-8 top-4 h-28 w-px bg-white/70"></div>
      <h2 class="font-display text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
        Join the Secret Service. <span class="text-brand-cream">♡</span>
      </h2>
      <p class="mt-4 text-lg font-medium text-white/90 md:text-xl">
        Subscribe and get a discount on your first order!
      </p>
      <form id="subscribe-form" class="mt-7 flex flex-col gap-3 sm:flex-row">
        <label class="flex h-16 flex-1 items-center gap-4 rounded-2xl bg-white/95 px-5 text-brand-ink shadow-sm">
          <span class="shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="m3 7 9 6 9-6"/>
            </svg>
          </span>
          <input
            type="email"
            required
            placeholder="Enter your email"
            class="w-full bg-transparent text-lg text-brand-ink placeholder:text-brand-ink/45 focus:outline-none"
          />
        </label>
        <button type="submit" class="h-16 rounded-2xl bg-brand-cream px-8 font-heading text-lg font-bold uppercase text-brand-ink transition-transform hover:-translate-y-0.5 sm:min-w-[220px]">
          Subscribe
          <span class="ml-2">🐾</span>
        </button>
      </form>
    </div>
  </div>
</section>

<footer class="bg-[#fbf2e7] text-brand-ink">
  <div class="container mx-auto grid gap-10 px-6 py-12 md:grid-cols-[0.9fr_1fr_1.1fr] md:gap-12 md:py-14">
    <div class="md:border-r md:border-[#eadfce] md:pr-10">
      <div class="font-display text-4xl font-bold uppercase text-brand-orange">
        PawKasa
      </div>
      <div class="mt-8 flex gap-3">
        {[
          {
            label: "Instagram",
            icon: (
              <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="5"/>
                <circle cx="12" cy="12" r="4.2"/>
                <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/>
              </svg>
            ),
          },
          {
            label: "TikTok",
            icon: (
              <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 4v10.5a4.5 4.5 0 1 1-4.5-4.5"/>
                <path d="M14 4c1 2.5 2.8 4.2 5 4.5"/>
              </svg>
            ),
          },
          {
            label: "YouTube",
            icon: (
              <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/>
                <path d="m10 15 5-3-5-3z"/>
              </svg>
            ),
          },
          {
            label: "Pinterest",
            icon: (
              <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21c1.5-3.5 4-12 4-14a4 4 0 1 0-8 0c0 1.8.8 3 2 3 1.7 0 2.5-1.8 2.5-3.2 0-1.1-.5-2-1.5-2"/>
              </svg>
            ),
          },
        ].map((social) => (
          <a href="#" aria-label={social.label} class="flex h-11 w-11 items-center justify-center rounded-full bg-[#f2dfc7] transition-colors hover:bg-brand-orange hover:text-white">
            {social.icon}
          </a>
        ))}
      </div>
    </div>

    <div class="md:border-r md:border-[#eadfce] md:px-10">
      <h4 class="font-heading text-xl font-bold uppercase">Company</h4>
      <ul class="mt-7 space-y-6 text-lg">
        <li><a href="/about" class="transition-colors hover:text-brand-orange">About Us</a></li>
        <li><a href="/privacy" class="transition-colors hover:text-brand-orange">Privacy Policy</a></li>
        <li><a href="/shipping" class="transition-colors hover:text-brand-orange">Shipping Policy</a></li>
        <li><a href="/contact" class="transition-colors hover:text-brand-orange">Wholesale</a></li>
      </ul>
    </div>

    <div class="md:pl-10">
      <h4 class="font-heading text-xl font-bold uppercase">Contact Us</h4>
      <p class="mt-7 text-lg">Have a question? Ask our humans. <span class="text-brand-orange">♡</span></p>
      <ul class="mt-7 space-y-5 text-base md:text-lg">
        <li class="flex gap-4">
          <svg class="mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <path d="m3 7 9 6 9-6"/>
          </svg>
          <span>hello@pawkasa.com</span>
        </li>
        <li class="flex gap-4">
          <svg class="mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/>
            <path d="M12 7v5l3 2"/>
          </svg>
          <span>Mon - Fri: 9AM - 6PM (PST)<br/>Sat - Sun: 10AM - 4PM (PST)</span>
        </li>
        <li class="flex gap-4">
          <svg class="mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span>123 Kitty Lane, Meow Town,<br/>CA 90210, USA</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="bg-brand-blue">
    <div class="container mx-auto px-6 py-6 text-center text-sm text-brand-ink">
      &copy; {year} PAWKASA. All rights reserved. <span class="ml-2">🐾</span>
    </div>
  </div>
</footer>

<script>
  document.getElementById('subscribe-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = (e.target as HTMLFormElement).querySelector('input');
    if (input) {
      alert('Welcome to PawKasa! Check your inbox for your discount code.');
      input.value = '';
    }
  });
</script>
