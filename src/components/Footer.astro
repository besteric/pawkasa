---
const year = new Date().getFullYear();
---

<section class="bg-brand-cream py-20">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-brand-orange">🐾 Newsletter</p>
      <h2 class="mt-3 font-heading font-bold text-4xl md:text-5xl text-brand-ink leading-tight">
        A little gift for you & your cat
      </h2>
      <p class="mt-4 text-lg text-brand-ink/70">
        Get 10% off your first order + early access to new arrivals & exclusive drops
      </p>
      <form id="subscribe-form" class="mt-8 flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
        <input
          type="email"
          required
          placeholder="Enter your email"
          class="flex-1 h-12 px-5 rounded-full border border-border bg-card text-brand-ink text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange"
        />
        <button type="submit" class="h-12 px-7 rounded-full bg-brand-orange text-white font-medium hover:bg-brand-orange/90 transition-colors whitespace-nowrap">
          Get My 10% Off 🐾
        </button>
      </form>
      <p class="mt-4 text-sm text-brand-ink/50">
        No spam. Just cute things and better homes for your cat.
      </p>
      <div class="mt-8 pt-8 border-t border-brand-ink/10">
        <p class="text-sm font-medium text-brand-ink/60">Follow us for daily cat moments</p>
        <div class="mt-3 flex justify-center gap-3">
          <a href="#" aria-label="Instagram" class="w-10 h-10 rounded-full bg-brand-ink/10 hover:bg-brand-orange hover:text-white text-brand-ink flex items-center justify-center transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="#" aria-label="YouTube" class="w-10 h-10 rounded-full bg-brand-ink/10 hover:bg-brand-orange hover:text-white text-brand-ink flex items-center justify-center transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
          </a>
          <a href="#" aria-label="TikTok" class="w-10 h-10 rounded-full bg-brand-ink/10 hover:bg-brand-orange hover:text-white text-brand-ink flex items-center justify-center transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.27 6.27 0 0 0-1-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 10.86 4.46A6.28 6.28 0 0 0 15.84 14V8.29a8.28 8.28 0 0 0 4.85 1.56V6.41a4.85 4.85 0 0 1-1.1.28z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="bg-brand-ink text-brand-cream">
  <div class="container mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">
    <div>
      <div class="font-display font-bold text-3xl text-brand-orange">PawKasa</div>
      <p class="mt-4 text-sm text-brand-cream/70 leading-relaxed">
        The Journey with Cats. Premium cat scratching boards designed for genuine
        connection between cats and their families.
      </p>
    </div>
    <div>
      <h4 class="font-semibold mb-4 text-sm uppercase tracking-wider text-brand-orange">Explore</h4>
      <ul class="space-y-2 text-sm text-brand-cream/80">
        <li><a href="/" class="hover:text-brand-orange">Home</a></li>
        <li><a href="/about" class="hover:text-brand-orange">About us</a></li>
        <li><a href="/products" class="hover:text-brand-orange">Products</a></li>
        <li><a href="/contact" class="hover:text-brand-orange">Contact</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold mb-4 text-sm uppercase tracking-wider text-brand-orange">Contact</h4>
      <ul class="space-y-2 text-sm text-brand-cream/80">
        <li>info@pawkasa.com</li>
        <li>Seoul, South Korea</li>
        <li>Global partnerships welcome</li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold mb-4 text-sm uppercase tracking-wider text-brand-orange">Follow</h4>
      <div class="flex gap-3">
        <a href="#" aria-label="Instagram" class="w-10 h-10 rounded-full bg-brand-cream/10 hover:bg-brand-orange hover:text-white flex items-center justify-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
        <a href="#" aria-label="YouTube" class="w-10 h-10 rounded-full bg-brand-cream/10 hover:bg-brand-orange hover:text-white flex items-center justify-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
        </a>
        <a href="#" aria-label="Website" class="w-10 h-10 rounded-full bg-brand-cream/10 hover:bg-brand-orange hover:text-white flex items-center justify-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        </a>
      </div>
    </div>
  </div>
  <div class="border-t border-brand-cream/10">
    <div class="container mx-auto px-6 py-6 text-xs text-brand-cream/60 flex flex-col sm:flex-row justify-between gap-2">
      <span>&copy; {year} PawKasa — Inspired tribute site.</span>
      <span>Crafted with care for cats and the people who love them.</span>
    </div>
  </div>
</footer>

<script>
  document.getElementById('subscribe-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = (e.target as HTMLFormElement).querySelector('input');
    if (input) {
      alert('🎉 Welcome to PawKasa! Check your inbox for your 10% off code.');
      input.value = '';
    }
  });
</script>